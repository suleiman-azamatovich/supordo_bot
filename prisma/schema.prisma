generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  SELLER
  ADMIN
  CASHIER
}

enum BoardStatus {
  AVAILABLE
  BOOKED // Зарезервировано для будущего функционала бронирования
  RENTED
  SERVICE
}

enum BookingStatus {
  DRAFT
  WAIT_PAYMENT
  WAIT_ADMIN
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum RentalStatus {
  CREATED
  WAIT_PAYMENT
  WAIT_ADMIN
  RENTED
  WAIT_RETURN
  RETURNED
  CANCELLED
}

enum PaymentProofStatus {
  SUBMITTED
  APPROVED
  REJECTED
}

enum PaymentProofKind {
  BOOKING
  RENTAL
  OVERDUE
  EXTENSION
}

enum AuditAction {
  CREATED
  WALKIN_CREATED
  WAIT_PAYMENT
  SUBMITTED
  APPROVED_AND_RENTED
  RETURNED
  CANCELLED
  EXTENDED
  EXTEND_REQUESTED
  EXTEND_REJECTED
  CLOSE_OVERDUE
  PAYMENT_APPROVED
  PAYMENT_REJECTED
  ROLE_CHANGED
  MODE_TOGGLED
  QR_UPDATED
  TARIFF_CREATED
  TARIFF_UPDATED
  TARIFF_DELETED
  DISCOUNT_SET
}

model User {
  id              Int      @id @default(autoincrement())
  tgId            BigInt   @unique
  role            Role     @default(CLIENT)
  name            String
  phone           String?
  spotId          Int?
  /// Персональная скидка в процентах (0..100). Применяется ко всем новым арендам/продлениям.
  discountPercent Int      @default(0)
  /// Причина/комментарий к скидке (для аудита, отображается админу).
  discountNote    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  spot           Spot?          @relation(fields: [spotId], references: [id])
  bookings       Booking[]
  rentals        Rental[]       @relation("RentalClient")
  sellerRentals  Rental[]       @relation("RentalSeller")
  paymentProofs  PaymentProof[] @relation("PaymentCreator")
  reviewedProofs PaymentProof[] @relation("PaymentReviewer")
  auditLogs      AuditLog[]
  notifications  Notification[]
}

model Spot {
  id       Int     @id @default(autoincrement())
  name     String
  address  String?
  isActive Boolean @default(true)

  boards   Board[]
  tariffs  Tariff[]
  sellers  User[]
  bookings Booking[]
  rentals  Rental[]
}

model Board {
  id          Int         @id @default(autoincrement())
  spotId      Int
  code        String      @unique
  title       String
  imageFileId String?
  status      BoardStatus @default(AVAILABLE)

  spot     Spot      @relation(fields: [spotId], references: [id])
  bookings Booking[]
  rentals  Rental[]

  @@index([status])
  @@index([spotId])
}

model Tariff {
  id              Int     @id @default(autoincrement())
  spotId          Int
  name            String
  durationMinutes Int
  price           Int
  /// Акционная цена (если задана и меньше `price` — используется как эффективная).
  /// Клиенту показывается зачёркнутая `price` → `promoPrice`.
  promoPrice      Int?
  sortOrder       Int     @default(0)
  isActive        Boolean @default(true)

  spot    Spot     @relation(fields: [spotId], references: [id])
  rentals Rental[]

  @@index([spotId, isActive])
}

model Booking {
  id        Int           @id @default(autoincrement())
  userId    Int
  spotId    Int
  boardId   Int?
  tariffId  Int?
  startAt   DateTime
  endAt     DateTime
  status    BookingStatus @default(DRAFT)
  createdAt DateTime      @default(now())

  user  User   @relation(fields: [userId], references: [id])
  spot  Spot   @relation(fields: [spotId], references: [id])
  board Board? @relation(fields: [boardId], references: [id])
}

model Rental {
  id                  Int          @id @default(autoincrement())
  userId              Int
  spotId              Int
  boardId             Int
  tariffId            Int?
  sellerUserId        Int?
  clientName          String?
  startAt             DateTime?
  endAt               DateTime?
  extraMinutes        Int          @default(0)
  extraCost           Int          @default(0)
  pendingExtraMinutes Int?
  /// Сумма к оплате за продление, зафиксированная в момент запроса (снапшот).
  /// Используется, чтобы изменение цены тарифа не влияло на уже запрошенное продление.
  pendingExtraAmount  Int?
  /// Эффективная цена тарифа в момент создания аренды (после акции, до личной скидки). null для старых записей.
  tariffPriceKgs      Int?
  /// Исходная (доакционная) цена тарифа. Заполняется только когда акция была активна на момент создания.
  tariffOriginalPriceKgs Int?
  /// Фактическая цена базовой аренды после применения скидки клиента. null для старых записей.
  basePriceKgs        Int?
  /// Снапшот процента скидки клиента на момент создания аренды.
  discountPercent     Int          @default(0)
  status              RentalStatus @default(CREATED)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  user   User    @relation("RentalClient", fields: [userId], references: [id])
  seller User?   @relation("RentalSeller", fields: [sellerUserId], references: [id])
  spot   Spot    @relation(fields: [spotId], references: [id])
  board  Board   @relation(fields: [boardId], references: [id])
  tariff Tariff? @relation(fields: [tariffId], references: [id])

  @@index([status])
  @@index([spotId])
  @@index([boardId])
  @@index([userId])
  @@index([startAt])
}

model PaymentProof {
  id         Int                @id @default(autoincrement())
  kind       PaymentProofKind
  refId      Int
  amount     Int
  fileId     String?
  text       String?
  status     PaymentProofStatus @default(SUBMITTED)
  createdAt  DateTime           @default(now())
  userId     Int
  reviewedBy Int?
  reviewedAt DateTime?

  user     User  @relation("PaymentCreator", fields: [userId], references: [id])
  reviewer User? @relation("PaymentReviewer", fields: [reviewedBy], references: [id])

  @@index([status])
  @@index([kind, refId])
}

model AuditLog {
  id          Int         @id @default(autoincrement())
  actorUserId Int
  entityType  String
  entityId    Int
  action      AuditAction
  metaJson    Json?
  createdAt   DateTime    @default(now())

  actor User @relation(fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  text      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}

model Setting {
  key   String @id
  value String
}

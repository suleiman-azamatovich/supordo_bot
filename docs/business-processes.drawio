                    <mxGeometry x="215" y="80" width="80" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="tl_l3" value="endTime" style="text;html=1;align=center;fontSize=10;fontColor=#b85450;" vertex="1" parent="timeline_box">
                    <mxGeometry x="290" y="80" width="60" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="tl_l4" value="graceEnd" style="text;html=1;align=center;fontSize=10;fontColor=#b85450;fontStyle=1;" vertex="1" parent="timeline_box">
                    <mxGeometry x="440" y="80" width="70" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="tl_status" value="Статусы:  ---------- RENTED ----------------------------------- -&gt; WAIT_RETURN -&gt;" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="timeline_box">
                    <mxGeometry x="30" y="200" width="600" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="tl_dates" value="startAt = начало | endTime = startAt + (тариф + extra) x 60000 | graceEnd = endTime + 10мин" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="timeline_box">
                    <mxGeometry x="30" y="240" width="600" height="30" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram id="board-status" name="Статусы досок">
        <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="bt" value="ЖИЗНЕННЫЙ ЦИКЛ ДОСКИ (BoardStatus)" style="text;html=1;align=center;fontSize=16;fillColor=none;strokeColor=none;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="300" y="20" width="500" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="b_avail" value="&lt;b&gt;AVAILABLE&lt;/b&gt;&lt;br&gt;&lt;br&gt;Доска свободна.&lt;br&gt;Готова к аренде.&lt;br&gt;Видна клиентам." style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=middle;align=center;" vertex="1" parent="1">
                    <mxGeometry x="100" y="200" width="200" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="b_rented" value="&lt;b&gt;RENTED&lt;/b&gt;&lt;br&gt;&lt;br&gt;Доска арендована.&lt;br&gt;Привязана к аренде.&lt;br&gt;Недоступна другим." style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=middle;align=center;" vertex="1" parent="1">
                    <mxGeometry x="500" y="200" width="200" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="b_service" value="&lt;b&gt;SERVICE&lt;/b&gt;&lt;br&gt;&lt;br&gt;На обслуживании.&lt;br&gt;Недоступна.&lt;br&gt;Только админ." style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=middle;align=center;" vertex="1" parent="1">
                    <mxGeometry x="100" y="470" width="200" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="be1" value="createRental()&lt;br&gt;createWalkinRental()" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeWidth=2;" edge="1" source="b_avail" target="b_rented" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="be2" value="acceptReturn()&lt;br&gt;cancelRental()" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeWidth=2;" edge="1" source="b_rented" target="b_avail" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="600" y="160"/>
                            <mxPoint x="200" y="160"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="be3" value="board:service" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;" edge="1" source="b_avail" target="b_service" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="be4" value="board:available" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;" edge="1" source="b_service" target="b_avail" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="50" y="545"/>
                            <mxPoint x="50" y="275"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="b_note" value="&lt;b&gt;ВАЖНО:&lt;/b&gt;&lt;br&gt;&lt;br&gt;- Доска блокируется (-&gt; RENTED) ДО оплаты&lt;br&gt;  (при создании аренды в статусе CREATED)&lt;br&gt;- Это защита от двойной аренды&lt;br&gt;- Доска освобождается только при RETURNED или CANCELLED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
                    <mxGeometry x="800" y="200" width="380" height="130" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>

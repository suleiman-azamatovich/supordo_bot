                </mxCell>
                <mxCell id="leg3" value="Действие админа" style="rounded=1;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="legend" vertex="1">
                    <mxGeometry x="320" y="40" width="130" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="leg4" value="Ошибка / Просрочка" style="rounded=1;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="legend" vertex="1">
                    <mxGeometry x="20" y="80" width="130" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="leg5" value="Чат / Общение" style="rounded=1;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="legend" vertex="1">
                    <mxGeometry x="170" y="80" width="130" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="leg6" value="Межпроцессная связь" style="rounded=0;html=1;dashed=1;strokeColor=#999999;" parent="legend" vertex="1">
                    <mxGeometry x="320" y="80" width="150" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="leg7" value="Грейс-период старта: 8 мин (рабоч.) / 10 сек (тест)&lt;br&gt;Грейс-период возврата: 10 мин (рабоч.) / 10 сек (тест)&lt;br&gt;Авто-отмена неоплаченной аренды: 15 мин" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontStyle=2;" parent="legend" vertex="1">

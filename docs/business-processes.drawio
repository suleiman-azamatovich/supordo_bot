    <diagram id="walkin-flow" name="Walk-in аренда">
        <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="800" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="wt" value="WALK-IN АРЕНДА (создаёт админ на точке)&lt;br&gt;Клиент пришёл лично. Оплата наличными. Без подтверждения через бота." style="text;html=1;align=center;fontSize=14;fillColor=none;strokeColor=none;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="200" y="20" width="700" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="w_start" value="" style="ellipse;fillColor=#000000;" vertex="1" parent="1">
                    <mxGeometry x="40" y="150" width="30" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="w1" value="1. Админ нажимает&lt;br&gt;&lt;b&gt;Walk-in аренда&lt;/b&gt;&lt;br&gt;seller:walkin" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
                    <mxGeometry x="110" y="120" width="170" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="w2" value="2. Выбирает доску&lt;br&gt;из свободных&lt;br&gt;walkin:board" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
                    <mxGeometry x="330" y="120" width="170" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="w3" value="3. Выбирает тариф&lt;br&gt;walkin:tariff" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
                    <mxGeometry x="550" y="120" width="170" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="w4" value="4. Вводит имя&lt;br&gt;клиента&lt;br&gt;(текстовое сообщение)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
                    <mxGeometry x="770" y="120" width="170" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="w5" value="createWalkinRental()&lt;br&gt;&lt;br&gt;Статус: RENTED&lt;br&gt;startAt = NOW&lt;br&gt;Доска: RENTED&lt;br&gt;clientName: заполнено" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
                    <mxGeometry x="990" y="100" width="190" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="w6" value="Таймер запущен!&lt;br&gt;Клиент катается" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
                    <mxGeometry x="1240" y="120" width="160" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="w_end" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;strokeWidth=3;" vertex="1" parent="1">
                    <mxGeometry x="1460" y="145" width="30" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="we0" edge="1" source="w_start" target="w1" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="we1" edge="1" source="w1" target="w2" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="we2" edge="1" source="w2" target="w3" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="we3" edge="1" source="w3" target="w4" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="we4" edge="1" source="w4" target="w5" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="we5" edge="1" source="w5" target="w6" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="we6" edge="1" source="w6" target="w_end" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="w_note" value="ОТЛИЧИЯ ОТ ОБЫЧНОЙ АРЕНДЫ:&lt;br&gt;&lt;br&gt;- Нет этапа оплаты через MBank&lt;br&gt;- Нет ожидания подтверждения админом&lt;br&gt;- Таймер стартует СРАЗУ (startAt = now)&lt;br&gt;- clientName заполняется вручную (не из Telegram)&lt;br&gt;- sellerUserId = ID админа, создавшего аренду&lt;br&gt;- Далее процесс возврата ОДИНАКОВЫЙ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="110" y="280" width="400" height="180" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram id="status-machine" name="Статусы аренды (State Machine)">
        <mxGraphModel dx="1600" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="st_title" value="МАШИНА СОСТОЯНИЙ АРЕНДЫ (RentalStatus)" style="text;html=1;align=center;fontSize=16;fillColor=none;strokeColor=none;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="400" y="20" width="500" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="st_created" value="&lt;b&gt;CREATED&lt;/b&gt;&lt;br&gt;&lt;br&gt;Аренда создана.&lt;br&gt;Доска заблокирована.&lt;br&gt;Оплата не начата." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;align=center;" vertex="1" parent="1">
                    <mxGeometry x="100" y="120" width="200" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="st_wait_pay" value="&lt;b&gt;WAIT_PAYMENT&lt;/b&gt;&lt;br&gt;&lt;br&gt;Ожидание оплаты.&lt;br&gt;QR MBank отправлен." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;align=center;" vertex="1" parent="1">
                    <mxGeometry x="400" y="120" width="200" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="st_wait_admin" value="&lt;b&gt;WAIT_ADMIN&lt;/b&gt;&lt;br&gt;&lt;br&gt;Чек отправлен.&lt;br&gt;Админ проверяет." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;align=center;" vertex="1" parent="1">
                    <mxGeometry x="700" y="120" width="200" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="st_rented" value="&lt;b&gt;RENTED&lt;/b&gt;&lt;br&gt;&lt;br&gt;Аренда активна!&lt;br&gt;Таймер идёт.&lt;br&gt;startAt установлен." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;align=center;" vertex="1" parent="1">
                    <mxGeometry x="1000" y="120" width="200" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="st_wait_ret" value="&lt;b&gt;WAIT_RETURN&lt;/b&gt;&lt;br&gt;&lt;br&gt;Время вышло!&lt;br&gt;Грейс истёк.&lt;br&gt;Просрочка: 10 сом/мин" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=top;align=center;" vertex="1" parent="1">
                    <mxGeometry x="1300" y="120" width="200" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="st_returned" value="&lt;b&gt;RETURNED&lt;/b&gt;&lt;br&gt;&lt;br&gt;Доска возвращена.&lt;br&gt;endAt установлен.&lt;br&gt;Доска: AVAILABLE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;align=center;" vertex="1" parent="1">
                    <mxGeometry x="1300" y="350" width="200" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="st_cancelled" value="&lt;b&gt;CANCELLED&lt;/b&gt;&lt;br&gt;&lt;br&gt;Отменено.&lt;br&gt;Доска: AVAILABLE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=top;align=center;" vertex="1" parent="1">
                    <mxGeometry x="400" y="450" width="200" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="st_e1" value="submitPayment()&lt;br&gt;авто" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="st_created" target="st_wait_pay" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="st_e2" value="submitPayment()&lt;br&gt;чек отправлен" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="st_wait_pay" target="st_wait_admin" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="st_e3" value="approveRental()&lt;br&gt;Админ одобрил" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="st_wait_admin" target="st_rented" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="st_e3b" value="rejectPayment()&lt;br&gt;Отклонено" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;strokeColor=#b85450;" edge="1" source="st_wait_admin" target="st_wait_pay" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="800" y="280"/>
                            <mxPoint x="500" y="280"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="st_e4" value="expiryChecker&lt;br&gt;грейс истёк" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="st_rented" target="st_wait_ret" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="st_e5" value="acceptReturn()&lt;br&gt;Доска принята" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="st_wait_ret" target="st_returned" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="st_e5b" value="acceptReturn()&lt;br&gt;Досрочный возврат" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="st_rented" target="st_returned" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1100" y="400"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="st_e6" value="extendRental()&lt;br&gt;Продлено" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;strokeColor=#82b366;curved=1;" edge="1" source="st_wait_ret" target="st_rented" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1250" y="80"/>
                            <mxPoint x="1100" y="80"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="st_e7" value="cancelRental()&lt;br&gt;Клиент отменил" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;strokeColor=#b85450;" edge="1" source="st_created" target="st_cancelled" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="200" y="500"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="st_e8" value="expiryChecker&lt;br&gt;15 мин без оплаты" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;strokeColor=#b85450;" edge="1" source="st_wait_pay" target="st_cancelled" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="st_walkin" value="" style="ellipse;fillColor=#000000;" vertex="1" parent="1">
                    <mxGeometry x="1080" y="50" width="20" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="st_ew" value="createWalkinRental()&lt;br&gt;Walk-in" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;strokeWidth=2;" edge="1" source="st_walkin" target="st_rented" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="st_note" value="&lt;b&gt;КЛЮЧЕВЫЕ МОМЕНТЫ:&lt;/b&gt;&lt;br&gt;&lt;br&gt;- Доска блокируется (RENTED) при CREATED&lt;br&gt;- startAt устанавливается только при RENTED&lt;br&gt;- Walk-in: сразу в RENTED, startAt = now&lt;br&gt;- Продление из WAIT_RETURN -&gt; RENTED&lt;br&gt;- Авто-отмена: 15 мин без оплаты&lt;br&gt;- Отклонение: WAIT_ADMIN -&gt; WAIT_PAYMENT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
                    <mxGeometry x="100" y="350" width="400" height="180" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram id="extension-flow" name="Продление и просрочка">
        <mxGraphModel dx="1600" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="ext_title" value="ПРОДЛЕНИЕ АРЕНДЫ И УПРАВЛЕНИЕ ПРОСРОЧКОЙ" style="text;html=1;align=center;fontSize=16;fillColor=none;strokeColor=none;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="350" y="20" width="600" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="ext_box1" value="ПУТЬ 1: Клиент запрашивает продление" style="swimlane;html=1;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="40" y="80" width="800" height="250" as="geometry"/>
                </mxCell>
                <mxCell id="ext_c1" value="Клиент нажимает&lt;br&gt;&lt;b&gt;Продлить&lt;/b&gt;&lt;br&gt;client:extend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="ext_box1">
                    <mxGeometry x="20" y="50" width="150" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="ext_c2" value="Выбирает&lt;br&gt;длительность&lt;br&gt;(15/30/60 мин)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="ext_box1">
                    <mxGeometry x="210" y="50" width="140" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="ext_c3" value="requestExtend()&lt;br&gt;&lt;br&gt;pendingExtraMinutes&lt;br&gt;= выбранные мин" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="ext_box1">
                    <mxGeometry x="390" y="40" width="170" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="ext_c4_yes" value="Админ одобряет&lt;br&gt;ext:approve&lt;br&gt;&lt;br&gt;extendRental()&lt;br&gt;extraMinutes += N" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="ext_box1">
                    <mxGeometry x="600" y="40" width="170" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="ext_c4_no" value="Отклонено&lt;br&gt;ext:reject&lt;br&gt;&lt;br&gt;pendingExtra = null" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="ext_box1">
                    <mxGeometry x="600" y="150" width="170" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="ex_e1" edge="1" source="ext_c1" target="ext_c2" parent="ext_box1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ex_e2" edge="1" source="ext_c2" target="ext_c3" parent="ext_box1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ex_e3" value="Да" style="html=1;" edge="1" source="ext_c3" target="ext_c4_yes" parent="ext_box1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ex_e4" value="Нет" style="html=1;" edge="1" source="ext_c3" target="ext_c4_no" parent="ext_box1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ext_box2" value="ПУТЬ 2: Админ продлевает вручную" style="swimlane;html=1;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="40" y="360" width="800" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="ext_a1" value="Админ заходит в&lt;br&gt;&lt;b&gt;Аренды&lt;/b&gt; или&lt;br&gt;&lt;b&gt;Возвраты&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="ext_box2">
                    <mxGeometry x="20" y="50" width="150" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="ext_a2" value="Нажимает&lt;br&gt;&lt;b&gt;Продлить&lt;/b&gt;&lt;br&gt;admin:extend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="ext_box2">
                    <mxGeometry x="210" y="50" width="150" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="ext_a3" value="Выбирает время&lt;br&gt;admin:extend_confirm" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="ext_box2">
                    <mxGeometry x="400" y="50" width="150" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="ext_a4" value="extendRental()&lt;br&gt;&lt;br&gt;Если WAIT_RETURN:&lt;br&gt;- просрочка покрывается&lt;br&gt;- netMin = max(0, N - overdue)&lt;br&gt;- статус -&gt; RENTED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="ext_box2">
                    <mxGeometry x="590" y="35" width="190" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="exa1" edge="1" source="ext_a1" target="ext_a2" parent="ext_box2">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="exa2" edge="1" source="ext_a2" target="ext_a3" parent="ext_box2">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="exa3" edge="1" source="ext_a3" target="ext_a4" parent="ext_box2">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="overdue_box" value="УПРАВЛЕНИЕ ПРОСРОЧКОЙ" style="swimlane;html=1;startSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="40" y="590" width="800" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="od_calc" value="&lt;b&gt;Расчёт просрочки:&lt;/b&gt;&lt;br&gt;&lt;br&gt;totalMin = тариф + extraMinutes&lt;br&gt;endAt = startAt + totalMin&lt;br&gt;graceEnd = endAt + 10мин&lt;br&gt;&lt;br&gt;overdueMin = (now - graceEnd) / 60&lt;br&gt;overdueCost = overdueMin x 10 сом" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="overdue_box">
                    <mxGeometry x="20" y="40" width="250" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="od_close" value="&lt;b&gt;closeOverdue():&lt;/b&gt;&lt;br&gt;&lt;br&gt;Покрывает просрочку&lt;br&gt;без добавления времени.&lt;br&gt;&lt;br&gt;overdueMin -&gt; extraMinutes&lt;br&gt;(нет чистого выигрыша)&lt;br&gt;WAIT_RETURN -&gt; RENTED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="overdue_box">
                    <mxGeometry x="300" y="40" width="210" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="od_pay" value="&lt;b&gt;Оплата просрочки:&lt;/b&gt;&lt;br&gt;&lt;br&gt;completeReturn() создаёт&lt;br&gt;PaymentProof(OVERDUE)&lt;br&gt;&lt;br&gt;Клиенту: Задолженность:&lt;br&gt;X сом. Оплатите через MBank&lt;br&gt;&lt;br&gt;Админ одобряет/отклоняет" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="overdue_box">
                    <mxGeometry x="550" y="40" width="220" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="formula_box" value="&lt;b&gt;ФОРМУЛА ПРОДЛЕНИЯ С ПРОСРОЧКОЙ&lt;/b&gt;&lt;br&gt;&lt;br&gt;Пример: аренда просрочена на 5 мин, клиент запросил +15 мин&lt;br&gt;&lt;br&gt;1. extraMinutes += 15&lt;br&gt;2. overdueMinutes = 5 (текущая)&lt;br&gt;3. netMinutes = max(0, 15 - 5) = 10 мин (реальный выигрыш)&lt;br&gt;4. Статус: WAIT_RETURN -&gt; RENTED&lt;br&gt;&lt;br&gt;Клиент видит: +15 мин (из них 5 покрыли просрочку, чистый выигрыш: 10 мин)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
                    <mxGeometry x="880" y="360" width="500" height="200" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram id="expiry-checker" name="Expiry Checker">
        <mxGraphModel dx="1600" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="exp_title" value="ФОНОВЫЙ ПРОЦЕСС: EXPIRY CHECKER (каждые 30 секунд)" style="text;html=1;align=center;fontSize=16;fillColor=none;strokeColor=none;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="350" y="20" width="600" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="exp_cancel_box" value="1. АВТО-ОТМЕНА НЕОПЛАЧЕННЫХ АРЕНД" style="swimlane;html=1;startSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="40" y="80" width="780" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="ec1" value="Найти аренды со&lt;br&gt;статусом CREATED&lt;br&gt;или WAIT_PAYMENT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="exp_cancel_box">
                    <mxGeometry x="20" y="50" width="160" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="ec2" value="createdAt &lt;&lt;br&gt;now - 15 мин?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="exp_cancel_box">
                    <mxGeometry x="220" y="40" width="140" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="ec3" value="cancelRental()&lt;br&gt;&lt;br&gt;Статус -&gt; CANCELLED&lt;br&gt;Доска -&gt; AVAILABLE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="exp_cancel_box">
                    <mxGeometry x="410" y="40" width="170" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="ec4" value="Клиенту:&lt;br&gt;Аренда отменена -&lt;br&gt;не оплачена вовремя" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="exp_cancel_box">
                    <mxGeometry x="620" y="40" width="140" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="ece1" edge="1" source="ec1" target="ec2" parent="exp_cancel_box">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ece2" value="Да" style="html=1;" edge="1" source="ec2" target="ec3" parent="exp_cancel_box">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ece3" edge="1" source="ec3" target="ec4" parent="exp_cancel_box">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="exp_warn_box" value="2. ПРЕДУПРЕЖДЕНИЕ: 10% ВРЕМЕНИ ОСТАЛОСЬ" style="swimlane;html=1;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="40" y="310" width="780" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="ew1" value="Аренды со&lt;br&gt;статусом RENTED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="exp_warn_box">
                    <mxGeometry x="20" y="50" width="140" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="ew2" value="Осталось &lt;= 10%&lt;br&gt;от общего&lt;br&gt;времени?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="exp_warn_box">
                    <mxGeometry x="200" y="40" width="140" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="ew3" value="Клиенту:&lt;br&gt;Осталось менее X мин&lt;br&gt;&lt;br&gt;Админам:&lt;br&gt;доска + клиент + время" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="exp_warn_box">
                    <mxGeometry x="400" y="35" width="200" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="ew_note" value="&lt;i&gt;Однократно!&lt;br&gt;(warnedRentals)&lt;/i&gt;" style="text;html=1;fillColor=none;strokeColor=none;" vertex="1" parent="exp_warn_box">
                    <mxGeometry x="630" y="55" width="120" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="ewe1" edge="1" source="ew1" target="ew2" parent="exp_warn_box">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ewe2" value="Да" style="html=1;" edge="1" source="ew2" target="ew3" parent="exp_warn_box">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="exp_expired_box" value="3. ВРЕМЯ ВЫШЛО (грейс-период)" style="swimlane;html=1;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="40" y="500" width="550" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="ee1" value="now &gt;= endTime&lt;br&gt;AND&lt;br&gt;now &lt; graceEnd" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="exp_expired_box">
                    <mxGeometry x="20" y="40" width="160" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="ee2" value="Клиенту:&lt;br&gt;Время истекло!&lt;br&gt;Грейс-период X мин" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="exp_expired_box">
                    <mxGeometry x="240" y="45" width="180" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="eee1" value="Да" style="html=1;" edge="1" source="ee1" target="ee2" parent="exp_expired_box">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="exp_overdue_box" value="4. ГРЕЙС ИСТЁК - ПРОСРОЧКА" style="swimlane;html=1;startSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="40" y="690" width="700" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="eo1" value="now &gt;= graceEnd" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="exp_overdue_box">
                    <mxGeometry x="20" y="50" width="140" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="eo2" value="Статус -&gt;&lt;br&gt;WAIT_RETURN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="exp_overdue_box">
                    <mxGeometry x="210" y="50" width="150" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="eo3" value="Клиенту:&lt;br&gt;Грейс истёк!&lt;br&gt;10 сом/мин&lt;br&gt;&lt;br&gt;Админам:&lt;br&gt;Просрочка!" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="exp_overdue_box">
                    <mxGeometry x="420" y="35" width="190" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="eoe1" value="Да" style="html=1;" edge="1" source="eo1" target="eo2" parent="exp_overdue_box">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="eoe2" edge="1" source="eo2" target="eo3" parent="exp_overdue_box">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="timeline_box" value="ТАЙМЛАЙН АРЕНДЫ" style="swimlane;html=1;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="860" y="80" width="700" height="300" as="geometry"/>
                </mxCell>
                <mxCell id="tl_line" value="" style="endArrow=classic;html=1;strokeWidth=3;strokeColor=#333333;" edge="1" parent="timeline_box">

<mxfile host="65bd71144e">
    <diagram id="rental-flow" name="Аренда (основной поток)">
        <mxGraphModel dx="1454" dy="728" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1600" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title1" value="ОСНОВНОЙ ПОТОК АРЕНДЫ (CLIENT -&gt; ADMIN)&lt;br&gt;Клиент сканирует QR / выбирает доску -&gt; оплата -&gt; одобрение -&gt; таймер -&gt; возврат" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="400" y="20" width="800" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="lane_client" value="КЛИЕНТ" style="shape=swimlane;html=1;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=14;horizontal=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="80" width="2320" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="c_start" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;" parent="lane_client" vertex="1">
                    <mxGeometry x="40" y="100" width="30" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="c_scan" value="Сканирует QR-код&lt;br&gt;или выбирает доску&lt;br&gt;из списка" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lane_client" vertex="1">
                    <mxGeometry x="110" y="80" width="160" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="c_tariff" value="Выбирает тариф&lt;br&gt;(30м / 60м / 120м)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lane_client" vertex="1">
                    <mxGeometry x="320" y="80" width="160" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="c_safety" value="Принимает правила&lt;br&gt;безопасности" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lane_client" vertex="1">
                    <mxGeometry x="530" y="80" width="140" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="c_pay_qr" value="Получает QR MBank&lt;br&gt;для оплаты" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lane_client" vertex="1">
                    <mxGeometry x="910" y="80" width="140" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="c_wait" value="Ожидает&lt;br&gt;подтверждения&lt;br&gt;от админа" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="lane_client" vertex="1">
                    <mxGeometry x="1100" y="80" width="140" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="c_ride" value="Катается!&lt;br&gt;Таймер идёт" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="lane_client" vertex="1">
                    <mxGeometry x="1500" y="80" width="140" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="c_return_notif" value="Получает уведомление:&lt;br&gt;Верните доску!" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="lane_client" vertex="1">
                    <mxGeometry x="1700" y="80" width="150" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="c_return_board" value="Возвращает&lt;br&gt;доску на точку" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lane_client" vertex="1">
                    <mxGeometry x="1910" y="80" width="140" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="c_done" value="Готово!" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="lane_client" vertex="1">
                    <mxGeometry x="2110" y="80" width="120" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" parent="lane_client" source="c_start" target="c_scan" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;" parent="lane_client" source="c_scan" target="c_tariff" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;" parent="lane_client" source="c_tariff" target="c_safety" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_pay" style="edgeStyle=orthogonalEdgeStyle;" parent="lane_client" source="c_pay_qr" target="c_wait" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_ride" style="edgeStyle=orthogonalEdgeStyle;" parent="lane_client" source="c_ride" target="c_return_notif" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_ret1" style="edgeStyle=orthogonalEdgeStyle;" parent="lane_client" source="c_return_notif" target="c_return_board" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_ret2" style="edgeStyle=orthogonalEdgeStyle;" parent="lane_client" source="c_return_board" target="c_done" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="lane_system" value="СИСТЕМА (автоматически)" style="shape=swimlane;html=1;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=14;horizontal=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="360" width="2320" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="s_create" value="createRental()&lt;br&gt;&lt;br&gt;Статус: CREATED&lt;br&gt;Доска: RENTED&lt;br&gt;(заблокирована)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="lane_system" vertex="1">
                    <mxGeometry x="520" y="60" width="160" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="s_submit" value="submitPayment()&lt;br&gt;&lt;br&gt;WAIT_PAYMENT&lt;br&gt;-&gt; WAIT_ADMIN&lt;br&gt;PaymentProof: SUBMITTED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="lane_system" vertex="1">
                    <mxGeometry x="720" y="60" width="170" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="s_approve_r" value="approveRental()&lt;br&gt;&lt;br&gt;Статус: RENTED&lt;br&gt;startAt = now + 8мин&lt;br&gt;(грейс-период)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="lane_system" vertex="1">
                    <mxGeometry x="1290" y="60" width="170" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="s_expiry" value="expiryChecker&lt;br&gt;(каждые 30 сек)&lt;br&gt;&lt;br&gt;1. 10% осталось&lt;br&gt;2. Время вышло&lt;br&gt;3. Грейс истёк -&gt;&lt;br&gt;   WAIT_RETURN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="lane_system" vertex="1">
                    <mxGeometry x="1680" y="40" width="180" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="s_return" value="acceptReturn()&lt;br&gt;&lt;br&gt;Статус: RETURNED&lt;br&gt;endAt = now&lt;br&gt;Доска: AVAILABLE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="lane_system" vertex="1">
                    <mxGeometry x="2080" y="60" width="170" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="es1" style="edgeStyle=orthogonalEdgeStyle;" parent="lane_system" source="s_create" target="s_submit" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="lane_admin" value="АДМИНИСТРАТОР" style="shape=swimlane;html=1;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=14;horizontal=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="600" width="2320" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="a_notif" value="Получает уведомление:&lt;br&gt;Новая оплата" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="lane_admin" vertex="1">
                    <mxGeometry x="1060" y="70" width="150" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="a_review" value="Проверяет&lt;br&gt;фото чека" style="rhombus;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="lane_admin" vertex="1">
                    <mxGeometry x="1230" y="50" width="120" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="a_approve" value="Одобряет оплату&lt;br&gt;pay:approve" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="lane_admin" vertex="1">
                    <mxGeometry x="1390" y="40" width="140" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="a_reject" value="Отклоняет&lt;br&gt;pay:reject&lt;br&gt;-&gt; WAIT_PAYMENT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="lane_admin" vertex="1">
                    <mxGeometry x="1390" y="130" width="140" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="a_request_info" value="Запрашивает&lt;br&gt;доп. информацию&lt;br&gt;(чат с клиентом)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="lane_admin" vertex="1">
                    <mxGeometry x="1550" y="200" width="150" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="a_accept_ret" value="Принимает&lt;br&gt;возврат доски&lt;br&gt;seller:return" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="lane_admin" vertex="1">
                    <mxGeometry x="1900" y="70" width="150" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="ea1" style="edgeStyle=orthogonalEdgeStyle;" parent="lane_admin" source="a_notif" target="a_review" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ea2" value="Да" style="edgeStyle=orthogonalEdgeStyle;html=1;" parent="lane_admin" source="a_review" target="a_approve" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ea3" value="Нет" style="edgeStyle=orthogonalEdgeStyle;html=1;" parent="lane_admin" source="a_review" target="a_reject" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ea3b" value="?" style="edgeStyle=orthogonalEdgeStyle;html=1;" parent="lane_admin" source="a_review" target="a_request_info" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="cross1" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#6c8ebf;" parent="1" source="c_safety" target="s_create" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="cross2" value="QR MBank" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#d6b656;html=1;" parent="1" source="s_submit" target="c_pay_qr" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="cross4" value="Таймер запущен!" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#82b366;html=1;" parent="1" source="s_approve_r" target="c_ride" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="cross5" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#6c8ebf;" parent="1" source="c_return_board" target="s_return" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="cross3" value="Уведомление всем админам" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#82b366;html=1;" parent="1" source="c_wait" target="a_notif" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="cross3b" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#82b366;" parent="1" source="a_approve" target="s_approve_r" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="cross6" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#b85450;" parent="1" source="s_expiry" target="a_accept_ret" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="cross7" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#82b366;" parent="1" source="a_accept_ret" target="s_return" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="legend" value="ЛЕГЕНДА" style="swimlane;html=1;startSize=25;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="900" width="600" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="leg1" value="Действие клиента" style="rounded=1;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="legend" vertex="1">

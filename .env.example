# Env
BOT_TOKEN=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/subordo_bot

# Telegram ID супер-админов (через запятую)
ADMIN_TG_IDS=

# Telegram ID кассиров (через запятую)
# Кассир имеет доступ к доскам, кассе, walk-in, продлениям, возвратам, чату.
# Не имеет доступа к отчётам, тарифам, управлению ролями.
CASHIER_TG_IDS=

# Optional
TIMEZONE=Asia/Bishkek
LOG_LEVEL=info
